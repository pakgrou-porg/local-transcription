# ════════════════════════════════════════════════════════════
# Transcription Pipeline — Environment Configuration
# ════════════════════════════════════════════════════════════
# Copy to .env and fill in values. Never commit .env to version control.
#
# System dependency: ffmpeg must be on PATH
#   Debian/Ubuntu: apt install ffmpeg
#   Windows:       winget install ffmpeg
# ════════════════════════════════════════════════════════════

# ── Google OAuth2 ──────────────────────────────────────────
# Path to the OAuth2 client_secrets.json downloaded from Google Cloud Console
GOOGLE_CLIENT_SECRETS_FILE=client_secrets.json

# Path to store the OAuth2 token (created automatically on first auth)
GOOGLE_TOKEN_FILE=token.json

# Google Drive folder name containing source audio files
GOOGLE_DRIVE_SOURCE_FOLDER=ai_sources

# Subfolder name within the source folder for archived files
GOOGLE_DRIVE_ARCHIVE_FOLDER=archive

# ── Supabase ───────────────────────────────────────────────
# Supabase project URL (e.g., https://xxxx.supabase.co)
SUPABASE_URL=

# Supabase service role key (server-side only, never expose to client)
SUPABASE_SERVICE_KEY=

# ── Transcription Service ─────────────────────────────────
# Base URL of the Cohere Transcribe service (OpenAI Whisper-compatible)
TRANSCRIBE_BASE_URL=http://10.116.2.56:8101

# Model identifier sent in the transcription request
TRANSCRIBE_MODEL_ID=CohereLabs/cohere-transcribe-03-2026

# ISO 639-1 language code for transcription (e.g., en, fr, de)
TRANSCRIBE_LANGUAGE=en

# HTTP timeout in seconds for the transcription call
TRANSCRIBE_TIMEOUT_SECONDS=300

# ── Summarizer LLM Service ────────────────────────────────
# Base URL of the Nemotron-Nano LLM service (OpenAI Chat-compatible)
SUMMARIZER_BASE_URL=http://10.116.2.56:8100

# API key for the summarizer (leave blank for unauthenticated local endpoints)
SUMMARIZER_API_KEY=

# Model name/identifier sent in the summarizer request body
SUMMARIZER_MODEL=nvidia/nemotron-nano-30b

# HTTP timeout in seconds for the summarizer call
SUMMARIZER_TIMEOUT_SECONDS=120

# ── Email ──────────────────────────────────────────────────
# Recipient email address for HTML summary emails
GMAIL_DESTINATION_ADDRESS=

# ── Text Substitutions ────────────────────────────────────
# Path to the substitutions file (default: substitutions.txt next to main.py)
SUBSTITUTIONS_FILE=substitutions.txt

# ── Logging ────────────────────────────────────────────────
# Directory for rotating audit logs (default: ./logs)
LOG_DIR=./logs
